# Mahina Linux Kernel Minimal Config Fragment
# Authority: Volume II / 03_linux_architecture.md, DL-009
# Usage in WSL2:
#   cd /path/to/linux-6.6.x
#   make ARCH=x86_64 defconfig
#   scripts/kconfig/merge_config.sh .config /path/to/mahina/kernel/.config
#   make ARCH=x86_64 olddefconfig
#   make ARCH=x86_64 -j$(nproc) bzImage
#
# Full justification for every option: kernel/.config.notes

CONFIG_X86_64=y
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_NR_CPUS=256
CONFIG_HZ_250=y
CONFIG_PREEMPT_VOLUNTARY=y
CONFIG_NO_HZ_IDLE=y

# UEFI / EFI
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_VARS=y
CONFIG_FB_EFI=y

# Filesystems
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_POSIX_ACL=y
CONFIG_EXT4_FS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_FAT_FS=y
CONFIG_VFAT_FS=y
CONFIG_FUSE_FS=y

# VirtIO (QEMU)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_INPUT=y
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_VIRTIO_BALLOON=y

# DRM / KMS
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y

# Input
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_HID=y
CONFIG_USB_HID=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y

# USB
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y

# Networking
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_NETFILTER=y
CONFIG_NF_TABLES=y
CONFIG_UNIX=y
CONFIG_PACKET=y

# cgroups v2
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y

# Security
CONFIG_SECURITY=y
CONFIG_SECURITY_APPARMOR=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_CRYPTO=y
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_AES=y

# Kernel features (required by luna-init)
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_INOTIFY_USER=y
CONFIG_EPOLL=y
CONFIG_POSIX_TIMERS=y
CONFIG_FUTEX=y

# Symbols / printk
CONFIG_KALLSYMS=y
CONFIG_PRINTK=y

# Audio (PipeWire - Stage 1+)
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_VIRTIO=y

# Power management
CONFIG_PM=y
CONFIG_ACPI=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
